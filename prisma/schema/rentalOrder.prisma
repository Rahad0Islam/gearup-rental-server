model RentalOrder {
  id          String   @id @default(uuid())
  pickupDate   DateTime
  returnDate   DateTime
  actualPickupDate DateTime?
  actualReturnDate DateTime?
  status      rentalOrderStatus @default(PLACED)
  actualRentalPrice Float?
  lateFee    Float?
  totalDiscount Float?
  totalAmount  Float?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customerId  String
  customer    User     @relation(fields: [customerId], references: [id],onDelete: Cascade)

  rentalOrderItems rentalOrderItems[]
  payments payments[]
  reviews review[]

  @@map("rental_orders")
}